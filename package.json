{
  "name": "adventure-monorepo",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "adv-designer",
    "adv-widget",
    "adv-shopify",
    "shared/api/*"
  ],
  "scripts": {
    "dev:designer": "npm -w adv-designer run dev",
    "dev:widget": "npm -w adv-widget run dev",
    "dev:shopify": "npm -w adv-shopify run dev",
    "build:designer": "npm -w adv-designer run build",
    "build:widget": "npm -w adv-widget run build",
    "build:shopify": "npm -w adv-shopify run build",
    "lint:designer": "npm -w adv-designer run lint",
    "lint:widget": "npm -w adv-widget run lint",
    "lint:shopify": "npm -w adv-shopify run lint",
    "db:update": "node scripts/update-supabase.js",
    "sort:configs": "node scripts/sort-configs.js",
    "env:doctor": "node scripts/vercel-env-manager.js doctor",
    "env:diff": "node scripts/vercel-env-manager.js diff",
    "env:pull": "node scripts/vercel-env-manager.js pull",
    "env:push": "node scripts/vercel-env-manager.js push",
    "env:reset": "node scripts/vercel-env-manager.js reset",
    "env:push:dev": "node scripts/vercel-env-manager.js push --source env/.env.shared.local --target development --prune",
    "env:push:dev:dry": "node scripts/vercel-env-manager.js push --source env/.env.shared.local --target development --prune --dry-run",
    "env:push:prod": "node scripts/vercel-env-manager.js push --source env/.env.shared.production --target production --prune",
    "env:push:prod:dry": "node scripts/vercel-env-manager.js push --source env/.env.shared.production --target production --prune --dry-run",
    "env:reset:prod": "node scripts/vercel-env-manager.js reset --target production --yes",
    "env:reset:prod:dry": "node scripts/vercel-env-manager.js reset --target production --dry-run",
    "env:replace:prod": "node scripts/vercel-env-manager.js reset --target production --yes && node scripts/vercel-env-manager.js push --source env/.env.shared.production --target production --prune",
    "env:replace:prod:dry": "node scripts/vercel-env-manager.js reset --target production --dry-run && node scripts/vercel-env-manager.js push --source env/.env.shared.production --target production --prune --dry-run",
    "env:sync:prod": "bash env/sync-production-env.sh",
    "env:cleanup-local": "node scripts/sync-local-envs.js",
    "prod:designer": "sh -c 'cd adv-designer && vercel --prod --yes'",
    "prod:widget": "sh -c 'cd adv-widget && vercel --prod --yes'",
    "prod:ai-form-service": "sh -c 'cd adv-ai-form-service && vercel --prod --yes'",
    "prod": "sh -c 'npm run prod:designer & npm run prod:widget & npm run prod:ai-form-service & wait'",
    "deploy:designer": "npm run prod:designer",
    "deploy:widget": "npm run prod:widget",
    "deploy:ai-form-service": "npm run prod:ai-form-service",
    "deploy:apps": "npm run prod",
    "deploy": "npm run prod"
  }
}

